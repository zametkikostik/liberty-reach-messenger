# 🏰 Liberty Reach Messenger - Environment Variables
# Copy this file to .env.local and fill in your actual values

# ═══════════════════════════════════════════════════════════════════════════
# PINATA IPFS CONFIGURATION
# Get your keys from: https://app.pinata.cloud/developers
# ═══════════════════════════════════════════════════════════════════════════

# JWT Authentication (Recommended)
PINATA_JWT=YOUR_PINATA_JWT_HERE

# API Key Authentication (Alternative)
PINATA_API_KEY=YOUR_PINATA_API_KEY_HERE
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY_HERE

# ═══════════════════════════════════════════════════════════════════════════
# CLOUDFLARE WORKER CONFIGURATION
# Your deployed Worker URL
# ═══════════════════════════════════════════════════════════════════════════

CLOUDFLARE_WORKER_URL=https://liberty-reach-push.kostik.workers.dev

# ═══════════════════════════════════════════════════════════════════════════
# CLOUDFLARE D1 DIRECT API ACCESS (Optional - for development)
# Get from Cloudflare Dashboard → Workers & Pages → D1 → Your Database
# ═══════════════════════════════════════════════════════════════════════════

# Cloudflare API Token (with D1 read/write permissions)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_HERE

# Cloudflare Account ID
# Find at: https://dash.cloudflare.com/ (right sidebar)
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID_HERE

# D1 Database ID
# Find at: https://dash.cloudflare.com/?to=/:account/d1
CLOUDFLARE_D1_DATABASE_ID=YOUR_D1_DATABASE_ID_HERE

# ═══════════════════════════════════════════════════════════════════════════
# WEBSOCKET CONFIGURATION (Real-time updates)
# Cloudflare Worker WebSocket URL
# ═══════════════════════════════════════════════════════════════════════════

CLOUDFLARE_WEBSOCKET_URL=wss://liberty-reach-push.kostik.workers.dev/ws

# ═══════════════════════════════════════════════════════════════════════════
# PUSH NOTIFICATIONS CONFIGURATION
# Cloudflare Push Worker URL + FCM
# ═══════════════════════════════════════════════════════════════════════════

CLOUDFLARE_PUSH_URL=https://liberty-reach-push.kostik.workers.dev

# Firebase Cloud Messaging Server Key
# Get from: Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY_HERE

# Firebase Sender ID (for client)
FCM_SENDER_ID=YOUR_FCM_SENDER_ID_HERE

# ═══════════════════════════════════════════════════════════════════════════
# GIF PICKER CONFIGURATION
# Giphy API Key
# ═══════════════════════════════════════════════════════════════════════════

# Get API key from: https://developers.giphy.com/
GIPHY_API_KEY=YOUR_GIPHY_API_KEY_HERE

# ═══════════════════════════════════════════════════════════════════════════
# AI TRANSLATION CONFIGURATION
# OpenRouter API for AI translation
# ═══════════════════════════════════════════════════════════════════════════

# Get API key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# Translation model (Qwen 2.5 Coder recommended)
TRANSLATION_MODEL=qwen-2.5-coder-32b

# ═══════════════════════════════════════════════════════════════════════════
# SELF-DESTRUCT TIMER
# Auto-delete messages after specified time
# ═══════════════════════════════════════════════════════════════════════════

# Timer cleanup interval (in minutes)
TIMER_CLEANUP_INTERVAL=5

# ═══════════════════════════════════════════════════════════════════════════
# WEBRTC CONFIGURATION
# STUN/TURN servers for NAT traversal
# ═══════════════════════════════════════════════════════════════════════════

# Google STUN servers (free, no auth required)
STUN_SERVER_1=stun:stun.l.google.com:19302
STUN_SERVER_2=stun:stun1.l.google.com:19302
STUN_SERVER_3=stun:stun2.l.google.com:19302
STUN_SERVER_4=stun:stun3.l.google.com:19302
STUN_SERVER_5=stun:stun4.l.google.com:19302

# Optional: Custom TURN server (for better connectivity)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your_username
# TURN_PASSWORD=your_password

# ═══════════════════════════════════════════════════════════════════════════
# AI CONFIGURATION (Optional)
# For translation and summarization features
# ═══════════════════════════════════════════════════════════════════════════

# OpenRouter API (for LLM access)
OPENROUTER_API_KEY=sk-or-YOUR_OPENROUTER_KEY_HERE

# Ollama (for local AI, optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Admin peer ID (for Geo-Trace and emergency override)
ADMIN_PEER_ID=your_admin_peer_id_here

# ═══════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env.local to Git - it's already in .gitignore
# 2. Only .env.example should be committed
# 3. Use flutter_dotenv to load these values in the app
# 4. For production, use secure secret management (e.g., AWS Secrets Manager)
#
# ═══════════════════════════════════════════════════════════════════════════
