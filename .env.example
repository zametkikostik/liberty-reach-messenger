# Liberty Sovereign v0.7.0 - Environment Configuration
# Copy this to .env.local and fill in your actual values

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# OpenRouter API Key (required for fallback)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-actual-api-key-here

# OpenRouter Configuration
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct:free

# Ollama Configuration (local AI - primary)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# AI Timeouts
AI_TIMEOUT_SECS=30
AI_MAX_RETRIES=3

# ============================================================================
# P2P CONFIGURATION
# ============================================================================

# P2P Network Port
P2P_PORT=40000

# ============================================================================
# BLOCKCHAIN RPC (Optional)
# ============================================================================

RPC_URL=https://polygon-rpc.com
POCKET_RPC_URL=https://poly.api.pocket.network
LAVA_RPC_URL=https://g.w.lavanet.xyz:443/gateway/polygon/rpc-http/your-key

# ============================================================================
# STORAGE (Pinata IPFS)
# ============================================================================

PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# ============================================================================
# SECURITY
# ============================================================================

SECRET_LOVE_KEY=your-secret-salt-for-encryption

# ============================================================================
# ADMIN
# ============================================================================

ADMIN_PEER_ID=12D3KooWYourAdminPeerIDHere
