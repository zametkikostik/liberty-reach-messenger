# ============================================================================
# Liberty Reach - Environment Variables Template
# ============================================================================
# COPY this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!
# ============================================================================

# ============================================================================
# Pinata IPFS (File Storage)
# ============================================================================
# Get from: https://app.pinata.cloud/developers
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# ============================================================================
# Blockchain RPC (Polygon Network)
# ============================================================================
# Pocket Network (Primary)
POCKET_RPC_URL=https://poly.api.pocket.network

# Lava Network (Fallback)
LAVA_RPC_URL=https://g.w.lavanet.xyz:443/gateway/polygon/rpc-http/your_lava_key_here

# Generic RPC URL (for Flutter/Build)
RPC_URL=https://polygon-rpc.com

# ============================================================================
# AI Integration (OpenRouter)
# ============================================================================
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ============================================================================
# Admin Configuration
# ============================================================================
# Your PeerID from `cargo run` logs (starts with 12D3Koo...)
ADMIN_PEER_ID=

# ============================================================================
# Android Build (GitHub Actions Secrets)
# ============================================================================
# Add these to GitHub Secrets, NOT to .env.local!
# https://github.com/zametkikostik/liberty-reach-messenger/settings/secrets/actions

# KEYSTORE_BASE64: cat android/app/upload-keystore.jks | base64 | xclip -sel clip
# KEYSTORE_BASE64=

# KEYSTORE_PASSWORD: Your keystore password
# KEYSTORE_PASSWORD=

# KEY_ALIAS: Usually 'upload'
# KEY_ALIAS=upload

# KEY_PASSWORD: Your key password (same as keystore usually)
# KEY_PASSWORD=

# ============================================================================
# Security & Encryption
# ============================================================================
# Secret key for secure storage (Flutter)
# Generate: openssl rand -base64 32
SECRET_LOVE_KEY=your_secret_key_min_16_chars

# ============================================================================
# Docker & Deployment (Optional)
# ============================================================================
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# ============================================================================
# Wallet (Optional - For transactions only)
# ============================================================================
# NEVER commit this!
# WALLET_PRIVATE_KEY=0x...

OPENROUTER_API_KEY=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
RPC_URL=https://g.w.lavanet.xyz:443/gateway/polygon/rpc-http/510353c239edb26b7ef54b675ea3dbc8
SECRET_LOVE_KEY=Love
ADMIN_PEER_ID=12D3KooWMz35pNJk8viwb5A1DM5FbFgeVDUnDLPw9zWsWLKXw6YY

# Данные для ключа (путь к файлу на твоем диске)
STORE_FILE=/home/kostik/Рабочий стол/папка для программирования/liberty-sovereign/android/app/upload-keystore.jks
