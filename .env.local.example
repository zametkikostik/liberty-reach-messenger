# Liberty Reach — Environment Configuration
# Скопируйте этот файл в .env.local и заполните значения

# =============================================================================
# AI INTEGRATION
# =============================================================================

# OpenRouter API Key (получить: https://openrouter.ai/keys)
# Начните с sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Опционально: модель для OpenRouter
# OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Опционально: endpoint для локального Ollama
# OLLAMA_ENDPOINT=http://localhost:11437/api/generate

# =============================================================================
# STORAGE (PINATA IPFS)
# =============================================================================

# Pinata API Key (получить: https://app.pinata.cloud/developers)
PINATA_API_KEY=your-pinata-api-key

# Pinata Secret Key
PINATA_SECRET_KEY=your-pinata-secret-key

# =============================================================================
# WEB3 / CRYPTO WALLET
# =============================================================================

# RPC URL для Polygon (или другой EVM сети)
WEB3_RPC_URL=https://polygon-rpc.com

# Приватный ключ кошелька (опционально, для отправки транзакций)
# WEB3_PRIVATE_KEY=your-private-key-hex

# Адрес кошелька для просмотра баланса (опционально)
# WEB3_WATCH_ADDRESS=0xYourWalletAddress

# Кошелек администратора для комиссии (0.5% с trades)
ADMIN_WALLET=0xAdminWalletAddress

# =============================================================================
# TELEGRAM BRIDGE
# =============================================================================

# Telegram Bot Token (получить от @BotFather)
TELEGRAM_BOT_TOKEN=000000000:AAHYourBotToken

# =============================================================================
# EXCHANGE (BITGET / BYBIT)
# =============================================================================

# Bitget API credentials
BITGET_API_KEY=your-bitget-api-key
BITGET_SECRET=your-bitget-secret
BITGET_PASSPHRASE=your-bitget-passphrase

# Bybit API credentials
BYBIT_API_KEY=your-bybit-api-key
BYBIT_SECRET=your-bybit-secret

# =============================================================================
# ADMIN PANEL
# =============================================================================

# Email администратора (для идентификации)
ADMIN_EMAIL=zametkikostik@gmail.com

# Peer ID администратора (заполняется автоматически при первом запуске)
# ADMIN_PEER_ID=12D3KooW...

# Cloudflare API для KV (Geo-Trace)
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
KV_NAMESPACE_ID=your-kv-namespace-id

# =============================================================================
# NOTES
# =============================================================================
# 
# Для работы AI:
#   - Установите Ollama: curl -fsSL https://ollama.com/install.sh | sh
#   - Запустите модель: ollama run qwen2.5-coder:3b
#   - Или добавьте OPENROUTER_API_KEY для облачного AI
#
# Для работы Storage:
#   - Зарегистрируйтесь на https://pinata.cloud
#   - Создайте API ключи в разделе Developers
#
# Для работы Web3:
#   - Настройте RPC URL для нужной сети
#   - Для отправки транзакций добавьте WEB3_PRIVATE_KEY
#
# Для работы Telegram Bridge:
#   - Создайте бота через @BotFather в Telegram
#   - Скопируйте токен бота
#
# Для работы Exchange:
#   - Создайте API ключи на Bitget и/или Bybit
#   - Установите ADMIN_WALLET для получения комиссии
#
# Для работы Geo-Trace:
#   - Настройте Cloudflare KV для хранения метаданных
#   - Требуются права администратора
